# Cadena de conexión PostgreSQL.
# Local:    postgresql://postgres:postgres@localhost:5432/echo
# Supabase: postgresql://USER:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Clave para firmar los JWT (pon cualquier cadena larga y aleatoria)
SECRET_KEY=

# Opcionales (tienen valores por defecto)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API key de Groq (de momento el agente no la usa, pero está prevista)
GROQ_API_KEY=
